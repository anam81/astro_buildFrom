---
import { clients } from "../data/videos_client.js";

const toSlug = (title) =>
	title
		.toLowerCase()
		.replace(/\s+/g, "-")
		.replace(/[^a-z0-9-]/g, "");

const firstSlug = toSlug(clients[0].title);
---

<meta
	http-equiv="refresh"
	content={`0; url=${import.meta.env.BASE_URL}client/${firstSlug}`}
/>
