---
import VideoLayout from "../../../layouts/VideoLayout.astro";
import { videos } from "../../../data/videos.js";
import { clients } from "../../../data/videos_client.js";

export function getStaticPaths() {
    const toSlug = (title) =>
        title
            .toLowerCase()
            .replace(/\s+/g, "-")
            .replace(/[^a-z0-9-]/g, "");

    const worksWithoutFirst = videos.slice(1);
    const clientsWithoutFirst = clients.slice(1);

    const langs = ["de", "en"];

    return [
        ...worksWithoutFirst.flatMap((video) =>
            langs.map((lang) => ({
                params: {
                    lang,
                    type: "works",
                    slug: toSlug(video.title),
                },
                props: { video, type: "works", lang },
            })),
        ),

        ...clientsWithoutFirst.flatMap((video) =>
            langs.map((lang) => ({
                params: {
                    lang,
                    type: "client",
                    slug: toSlug(video.title),
                },
                props: { video, type: "client", lang },
            })),
        ),
    ];
}

const { video, type, lang } = Astro.props;

const list = type === "client" ? clients : videos;

// canonical (immer die echte URL dieser Seite)
const {slug } = Astro.params;
const base = "https://arnemuench.de";
const canonical = `${base}/${lang}/${type}/${slug}/`;
// Sprach-Alternativen
const en = `${base}/en/${type}/${slug}/`;
const de = `${base}/de/${type}/${slug}/`;
---

<VideoLayout
    video={video}
    type={type}
    list={list}
    lang={lang}
    canonical={canonical}
    enUrl={en}
    deUrl={de}
/>
