---
import { videos } from "../data/videos.js";

const toSlug = (title) =>
	title
		.toLowerCase()
		.replace(/\s+/g, "-")
		.replace(/[^a-z0-9-]/g, "");

const firstSlug = toSlug(videos[0].title);
---

<html>
	<head>
		<script is:inline>
			window.location.replace(`/works/${firstSlug}`);
		</script>
	</head>
	<body></body>
</html>
