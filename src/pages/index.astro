---
import { videos } from "../data/videos.js";

const toSlug = (title) =>
	title
		.toLowerCase()
		.replace(/\s+/g, "-")
		.replace(/[^a-z0-9-]/g, "");

const firstSlug = toSlug(videos[0].title);
---

<meta
	http-equiv="refresh"
	content={`0; url=${import.meta.env.BASE_URL}works/${firstSlug}`}
/>
