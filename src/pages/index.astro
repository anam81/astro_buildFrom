---
import VideoLayout from "../layouts/VideoLayout.astro";
import { videos } from "../data/videos.js";


const firstVideo = videos[0];
const lang  = "en";

const base = "https://arnemuench.de";
const canonical = `${base}/${lang}/motion-design/`;
const en = `${base}/en/motion-design/`;
const de = `${base}/de/motion-design/`;
---

<VideoLayout
    video={firstVideo}
    type="works"
    list={videos}
    lang={lang}
    canonical={canonical}
    enUrl={en}
    deUrl={de}
/>
