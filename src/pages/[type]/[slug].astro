---
import VideoLayout from "../../layouts/VideoLayout.astro";
import { videos } from "../../data/videos.js";
import { clients } from "../../data/videos_client.js";

export function getStaticPaths() {
  const toSlug = (title) =>
    title
      .toLowerCase()
      .replace(/\s+/g, "-")
      .replace(/[^a-z0-9-]/g, "");

  const worksWithoutFirst = videos.slice(1);
  const clientsWithoutFirst = clients.slice(1);
  return [
    ...worksWithoutFirst.map((video) => ({
      params: { slug: toSlug(video.title), type: "works" },
      props: { video, type: "works" },
    })),
    ...clientsWithoutFirst.map((video) => ({
      params: { slug: toSlug(video.title), type: "client" },
      props: { video, type: "client" },
    })),
  ];
}

const { video, type } = Astro.props;

const list = type === "client" ? clients : videos;
---

<VideoLayout video={video} type={type} list={list} />
