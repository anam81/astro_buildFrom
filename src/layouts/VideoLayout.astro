---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getFirstClientSlug } from "../utils/links.js";
import { videos } from "../data/videos.js";

const firstClientSlug = getFirstClientSlug(import.meta.env.BASE_URL);
const { video, type, list } = Astro.props;
const firstWorkVideo = videos[0];
---

<!doctype html>
<html lang="de">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>
            {video.title} - arnemuench.de - Motion Designer aus Köln - After Effects,
            Motion Graphics & Scripting
        </title>
        <meta
            name="description"
            content={type === "works"
                ? video.description +
                  " Portfolio & Projekte ansehen. Motion Designer aus Köln spezialisiert auf Motion Graphics, After Effects, Scripting und Sound Design."
                : video.description +
                  " Kundenprojekte ansehen. Motion Designer aus Köln spezialisiert auf Motion Graphics, After Effects, Scripting und Sound Design."}
        />
        <meta
            name="keywords"
            content="motion design, motion graphics, after effects, köln, cologne, scripts, sound design"
        />
        <meta name="author" content="Arne Münch" />

        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href={import.meta.env.BASE_URL + "apple-touch-icon.png"}
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href={import.meta.env.BASE_URL + "favicon-32x32.png"}
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href={import.meta.env.BASE_URL + "favicon-16x16.png"}
        />
        <link
            rel="icon"
            type="image/x-icon"
            href={import.meta.env.BASE_URL + "favicon.ico"}
        />
        <link rel="stylesheet" href={import.meta.env.BASE_URL + "style.css"} />
    </head>

    <body>
        <div class="container">
            <Header firstClientSlug={firstClientSlug} />

            <main>
                <div class="portfolio-wrapper">
                    <!-- 🎬 Video -->
                    <div class="video-wrapper" data-ratio={video.ratio}>
                        <iframe
                            src={`https://player.vimeo.com/video/${video.id}?title=0&byline=0&portrait=0&color=dd5424`}
                            allow="autoplay; fullscreen; picture-in-picture"
                            allowfullscreen></iframe>
                    </div>

                    <!-- 📝 Beschreibung -->
                    <div class="video-description">
                        <p set:html={video.description} />
                    </div>

                    <!-- 🧱 Grid -->
                    <div class="video-grid">
                        {
                            list
                                .filter((v) => v.id !== video.id)
                                .map((v) => {
                                    const slug = v.title
                                        .toLowerCase()
                                        .replace(/\s+/g, "-")
                                        .replace(/[^a-z0-9-]/g, "");

                                    return (
                                        <a
                                            href={
                                                type === "works" &&
                                                v.id === firstWorkVideo.id
                                                    ? import.meta.env.BASE_URL
                                                    : `${import.meta.env.BASE_URL}${type}/${slug}`
                                            }
                                            class="thumb"
                                        >
                                            <img
                                                data-id={v.id}
                                                data-ratio={v.ratio}
                                                alt={v.title}
                                            />
                                        </a>
                                    );
                                })
                        }
                    </div>
                </div>
            </main>

            <Footer />
        </div>

        <!-- 🔥 ALLE deine Scripts wieder hier rein -->

        <script is:inline>
            // Thumbnail Click + Fade
            document.querySelectorAll("a.thumb").forEach((link) => {
                link.addEventListener("click", (e) => {
                    e.preventDefault();

                    sessionStorage.setItem("fromGrid", "true");

                    const img = link.querySelector("img");
                    if (!img) return;

                    img.style.transition = "opacity 0.3s ease";
                    img.style.opacity = "0.2";

                    window.location.href = link.href;
                });
            });

            window.addEventListener("beforeunload", () => {
                sessionStorage.setItem("scrollY", window.scrollY);
            });

            window.addEventListener("load", () => {
                const wrapper = document.querySelector(".video-wrapper");
                const fromGrid = sessionStorage.getItem("fromGrid");

                if (!fromGrid) {
                    window.scrollTo(0, 0);
                }

                const savedScrollY = sessionStorage.getItem("scrollY");

                if (savedScrollY !== null && fromGrid) {
                    requestAnimationFrame(() => {
                        requestAnimationFrame(() => {
                            const top = parseInt(savedScrollY, 10);

                            window.scrollTo(0, top);
                        });
                    });
                }

                requestAnimationFrame(() => {
                    requestAnimationFrame(() => {
                        if (!wrapper) return;

                        const rect = wrapper.getBoundingClientRect();
                        const isVisible =
                            rect.top >= 0 && rect.bottom <= window.innerHeight;

                        if (!isVisible && fromGrid) {
                            const offset = 20;

                            const top =
                                wrapper.getBoundingClientRect().top +
                                window.pageYOffset -
                                offset;

                            window.scrollTo({
                                top,
                                behavior: "smooth",
                            });
                        }

                        document.body.classList.add("is-loaded");
                        sessionStorage.removeItem("fromGrid");
                    });
                });
            });
        </script>

        <script is:inline>
            // Thumbnail Load
            const thumbnailCache = JSON.parse(
                localStorage.getItem("thumbnailCache") || "{}",
            );

            document
                .querySelectorAll(".video-grid img")
                .forEach(async (img) => {
                    const id = img.dataset.id;

                    if (!id) return;

                    if (thumbnailCache[id]) {
                        img.src = thumbnailCache[id];
                        return;
                    }

                    try {
                        const res = await fetch(
                            `https://vimeo.com/api/oembed.json?url=https://vimeo.com/${id}`,
                        );
                        const data = await res.json();

                        img.src = data.thumbnail_url;

                        thumbnailCache[id] = data.thumbnail_url;
                        localStorage.setItem(
                            "thumbnailCache",
                            JSON.stringify(thumbnailCache),
                        );
                    } catch (err) {
                        console.error("Thumbnail Fehler:", id, err);
                    }
                });
        </script>

        <script is:inline>
            // Ratio
            window.addEventListener("load", () => {
                const wrapper = document.querySelector(".video-wrapper");
                if (!wrapper) return;

                const ratio = wrapper.dataset.ratio;

                wrapper.classList.remove(
                    "video-16-10",
                    "video-4-3",
                    "video-1-1",
                    "video-235-100",
                );

                if (ratio && ratio !== "16/9") {
                    wrapper.classList.add("video-" + ratio.replace("/", "-"));
                }
            });
        </script>
    </body>
</html>
