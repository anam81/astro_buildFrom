---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { videos } from "../data/videos.js";

const { video, type, list: videos } = Astro.props;
const firstWorkVideo = videos[0];

// 👉 HIER: list bauen + Thumbnails holen
const list = await Promise.all(
    videos.map(async (v) => {
        try {
            const res = await fetch(
                `https://vimeo.com/api/oembed.json?url=https://vimeo.com/${v.id}`,
            );
            const data = await res.json();

            return {
                ...v,
                thumbnail: data.thumbnail_url,
            };
        } catch (err) {
            return {
                ...v,
                thumbnail: "",
            };
        }
    }),
);
---

<!doctype html>
<html lang="de">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>
            {video.title} - arnemuench.de - Motion Designer aus Köln - After Effects,
            Motion Graphics, Sound & Scripting
        </title>
        <meta
            name="description"
            content="Motion Design, Animation, Character Rigging, After Effects, Template- & Scriptentwicklung, Sound Design"
        />
        <meta
            name="keywords"
            content="motion design, motion graphics, after effects, köln, cologne, scripts, sound design"
        />
        <meta name="author" content="Arne Münch" />

        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href={import.meta.env.BASE_URL + "apple-touch-icon.png"}
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href={import.meta.env.BASE_URL + "favicon-32x32.png"}
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href={import.meta.env.BASE_URL + "favicon-16x16.png"}
        />
        <link
            rel="icon"
            type="image/x-icon"
            href={import.meta.env.BASE_URL + "favicon.ico"}
        />
        <link rel="stylesheet" href={import.meta.env.BASE_URL + "style.css"} />
    </head>

    <body>
        <div class="container">
            <Header />

            <main>
                <div class="portfolio-wrapper">
                    <!-- 🎬 Video -->
                    <div class="video-wrapper" data-ratio={video.ratio}>
                        <iframe
                            src={`https://player.vimeo.com/video/${video.id}?title=0&byline=0&portrait=0&color=dd5424`}
                            allow="autoplay; fullscreen; picture-in-picture"
                            allowfullscreen></iframe>
                    </div>

                    <!-- 📝 Beschreibung -->
                    <div class="video-description">
                        <p set:html={video.description} />
                    </div>

                    <!-- 🧱 Grid -->
                    <div class="video-grid">
                        {
                            list
                                .filter((v) => v.id !== video.id)
                                .map((v) => {
                                    const slug = v.title
                                        .toLowerCase()
                                        .replace(/\s+/g, "-")
                                        .replace(/[^a-z0-9-]/g, "");

                                    return (
                                        <a
                                            href={
                                                type === "works" &&
                                                v.id === firstWorkVideo.id
                                                    ? import.meta.env.BASE_URL
                                                    : `${import.meta.env.BASE_URL}${type}/${slug}`
                                            }
                                            class="thumb"
                                        >
                                            <img
                                                src={v.thumbnail}
                                                data-ratio={v.ratio}
                                                alt={v.title}
                                                loading="lazy"
                                                decoding="async"
                                            />
                                        </a>
                                    );
                                })
                        }
                    </div>
                </div>
            </main>

            <Footer />
        </div>
        <script src="/scripts/main.js" defer></script>
    </body>
</html>
